---
import { getCollection } from "astro:content";
import MotionController from "../components/MotionController.astro";
import SocialIcon from "../components/SocialIcon.astro";
import { siteMetadata } from "../data/site";
import Layout from "../layouts/Layout.astro";

const projects = (await getCollection("projects")).sort(
  (left, right) => left.data.order - right.data.order,
);

const featuredProjects = projects.filter((project) => project.data.featured);
const supportingProjects = projects.filter((project) => !project.data.featured);
const projectLabels: Record<string, string> = {
  "fleetvigo-oms": "Operations Platform",
  "feedme-payment": "Merchant Platform",
  ezsub: "Enterprise Platform",
};

const projectSiteLabels: Record<string, string> = {
  "feedme-payment": "Official FeedMe site",
  ezsub: "UX Design Awards case study",
};
---

<Layout title={`${siteMetadata.name} | Portfolio`} description={siteMetadata.description}>
  <div class="page-shell">
    <header class="site-header" data-header>
      <a class="brand" href="#top" aria-label="Go to top">
        <span class="brand-mark brand-mark--photo">
          <img src="/avatar-circle.png" alt="Paul Chew" loading="eager" />
        </span>
        <span class="brand-copy">
          <strong>{siteMetadata.name}</strong>
          <small>{siteMetadata.role}</small>
        </span>
      </a>

      <a
        class="header-cta"
        href={siteMetadata.primaryCTA.href}
        target="_blank"
        rel="noreferrer"
      >
        {siteMetadata.primaryCTA.label}
      </a>
    </header>

    <main>
      <section class="hero" id="top">
        <div class="hero-copy">
          <div class="hero-identity" data-hero-item>
            <div class="hero-identity__copy">
              <p class="section-kicker">{siteMetadata.hero.kicker}</p>
              <p class="hero-identity__note">{siteMetadata.availability}</p>
            </div>
          </div>
          <h1 data-hero-item>{siteMetadata.name}</h1>
          <p class="hero-offer" data-hero-item>{siteMetadata.hero.offerLead}</p>
          <p class="hero-summary" data-hero-item>{siteMetadata.hero.summary}</p>

          <div class="hero-actions" data-hero-item>
            <a
              class="button button--primary"
              href={siteMetadata.primaryCTA.href}
              target="_blank"
              rel="noreferrer"
            >
              {siteMetadata.primaryCTA.label}
            </a>
            <a class="button button--secondary" href={siteMetadata.secondaryCTA.href}>
              {siteMetadata.secondaryCTA.label}
            </a>
          </div>

          <ul class="hero-socials" aria-label="Social links" data-hero-item>
            {
              siteMetadata.socialLinks.map((socialLink) => (
                <li>
                  <a href={socialLink.href} target="_blank" rel="noreferrer" aria-label={socialLink.label}>
                    <SocialIcon name={socialLink.id} />
                    <span>{socialLink.label}</span>
                  </a>
                </li>
              ))
            }
          </ul>

          <ul class="hero-proof" data-hero-item>
            {
              siteMetadata.hero.credibility.map((item) => (
                <li>{item}</li>
              ))
            }
          </ul>
        </div>

        <div class="hero-stage">
          <div class="hero-glow hero-glow--cyan"></div>
          <div class="hero-glow hero-glow--amber"></div>

          <div class="hero-stack" data-stage-layer data-depth>
            <article class="hero-stat-card hero-stat-card--lead glass-panel">
              <p class="screen-label">{siteMetadata.hero.snapshotCards[0].eyebrow}</p>
              <strong>{siteMetadata.hero.snapshotCards[0].value}</strong>
              <p>{siteMetadata.hero.snapshotCards[0].detail}</p>
            </article>

            <article class="hero-stat-card hero-stat-card--domains glass-panel">
              <p class="screen-label">{siteMetadata.hero.snapshotCards[1].eyebrow}</p>
              <div class="hero-stat-card__chips">
                {
                  siteMetadata.hero.snapshotCards[1].items?.map((item) => (
                    <span>{item}</span>
                  ))
                }
              </div>
            </article>

            <article class="hero-stat-card hero-stat-card--work glass-panel">
              <p class="screen-label">{siteMetadata.hero.snapshotCards[2].eyebrow}</p>
              <ul class="hero-stat-card__list">
                {
                  siteMetadata.hero.snapshotCards[2].items?.map((item) => (
                    <li>{item}</li>
                  ))
                }
              </ul>
            </article>
          </div>
        </div>
      </section>

      <section class="section" id="work">
        <div class="section-heading" data-reveal>
          <p class="section-kicker">Selected Work</p>
          <h2>Work across insurance, merchant software, and operations.</h2>
          <p>
            Products built for real use, operational depth, and dependable delivery.
          </p>
        </div>

        <div class="project-list">
          {
            featuredProjects.map((project, index) => (
              <article
                class:list={[
                  "project-story",
                  "project-card",
                  index % 2 === 1 && "project-story--reverse",
                ]}
                data-reveal
              >
                <div class="project-story__copy">
                  <p class="project-label">{projectLabels[project.id]}</p>

                  <div class="project-story__title-block">
                    <h3>{project.data.title}</h3>
                    {
                      project.data.liveUrl ? (
                        <a
                          class="project-link"
                          href={project.data.liveUrl}
                          target="_blank"
                          rel="noreferrer"
                        >
                          <span>{projectSiteLabels[project.id] ?? "Official site"}</span>
                          <span class="project-link__arrow" aria-hidden="true">-&gt;</span>
                        </a>
                      ) : null
                    }
                  </div>

                  <p class="project-tagline">{project.data.tagline}</p>

                  <div class="project-story__facts">
                    <div>
                      <span class="fact-label">What the business needed</span>
                      <p>{project.data.summary}</p>
                    </div>
                    <div>
                      <span class="fact-label">What I owned</span>
                      <p>{project.data.role}</p>
                    </div>
                    <div>
                      <span class="fact-label">Why it mattered</span>
                      <p>{project.data.outcome}</p>
                    </div>
                  </div>

                  <ul class="stack-list" aria-label={`${project.data.title} tech stack`}>
                    {
                      project.data.stack.map((item) => (
                        <li>{item}</li>
                      ))
                    }
                  </ul>
                </div>

                {
                  project.id === "fleetvigo-oms" ? (
                    <div class="project-story__media project-story__media--fleetvigo">
                      <figure class="device-frame device-frame--wide" data-depth>
                        <img
                          class="device-image"
                          src={project.data.screens?.[0] ?? project.data.coverImage}
                          alt={`${project.data.title} dashboard screen`}
                          loading="lazy"
                        />
                      </figure>
                      <figure class="device-frame device-frame--floating" data-depth>
                        <img
                          class="device-image device-image--top"
                          src={project.data.screens?.[1] ?? project.data.coverImage}
                          alt={`${project.data.title} workflow screen`}
                          loading="lazy"
                        />
                      </figure>
                    </div>
                  ) : project.id === "feedme-payment" ? (
                    <div class="project-story__media project-story__media--feedme">
                      <div class="device-stack">
                        <figure class="device-frame device-frame--desktop">
                          <img
                            class="device-image device-image--reference"
                            src={project.data.screens?.[0] ?? project.data.coverImage}
                            alt={`${project.data.title} desktop product view`}
                            loading="lazy"
                          />
                        </figure>
                        <figure class="device-frame device-frame--mobile">
                          <img
                            class="device-image device-image--reference"
                            src={project.data.screens?.[1] ?? project.data.screens?.[0] ?? project.data.coverImage}
                            alt={`${project.data.title} mobile product view`}
                            loading="lazy"
                          />
                        </figure>
                      </div>
                    </div>
                  ) : project.id === "ezsub" ? (
                    <div class="project-story__media project-story__media--ezsub">
                      <figure class="device-frame device-frame--card">
                        <img
                          class="device-image device-image--reference"
                          src={project.data.screens?.[0] ?? project.data.coverImage}
                          alt={`${project.data.title} award showcase`}
                          loading="lazy"
                        />
                      </figure>
                      <figure class="device-frame device-frame--ezsub-float" data-depth>
                        <img
                          class="device-image device-image--reference"
                          src={project.data.screens?.[1] ?? project.data.screens?.[0] ?? project.data.coverImage}
                          alt={`${project.data.title} interface collage`}
                          loading="lazy"
                        />
                      </figure>
                    </div>
                  ) : (
                    <div class="project-story__media project-story__media--single">
                      <figure class="device-frame device-frame--card">
                        <img
                          class="device-image device-image--reference"
                          src={project.data.screens?.[0] ?? project.data.coverImage}
                          alt={`${project.data.title} product view`}
                          loading="lazy"
                        />
                      </figure>
                    </div>
                  )
                }
              </article>
            ))
          }
        </div>
      </section>

      <section class="section">
        <div class="section-heading" data-reveal>
          <p class="section-kicker">Additional Experience</p>
          <h2>Other products built for real workflows.</h2>
        </div>

        <div class="supporting-grid" data-reveal>
          {
            supportingProjects.map((project) => (
              <article class="supporting-item">
                <strong>{project.data.title}</strong>
                <p>{project.data.summary}</p>
                <div class="supporting-item__stack">
                  {project.data.stack.map((s) => <span>{s}</span>)}
                </div>
                <small>{project.data.role}</small>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section section--about" id="about">
        <div class="section-heading" data-reveal>
          <p class="section-kicker">{siteMetadata.about.kicker}</p>
          <h2>{siteMetadata.about.title}</h2>
          <p>{siteMetadata.about.lead}</p>
        </div>

        <div class="about-layout">
          <div class="about-copy glass-panel" data-reveal>
            <div class="about-copy__intro">
              <figure class="about-portrait">
                <img src="/me.png" alt={`${siteMetadata.name} portrait`} loading="lazy" />
              </figure>
              <div class="about-copy__header">
                <p class="section-kicker">Profile</p>
                <h3>{siteMetadata.name}</h3>
                <p class="about-copy__role">{siteMetadata.role}</p>
                <p class="about-copy__summary">{siteMetadata.about.summary}</p>
              </div>
            </div>
            <div class="about-copy__text">
              {
                siteMetadata.about.paragraphs.map((paragraph) => (
                  <p>{paragraph}</p>
                ))
              }
            </div>
          </div>

          <div class="about-sidebar">
            <div class="about-highlights glass-panel" data-reveal>
              <p class="fit-title">Where I add the most value</p>
              <ul class="fit-list">
                {
                  siteMetadata.about.highlights.map((item) => (
                    <li>{item}</li>
                  ))
                }
              </ul>
            </div>

            <div class="about-highlights glass-panel" data-reveal>
              <p class="fit-title">How I usually work</p>
              <ul class="fit-list">
                {
                  siteMetadata.hero.proofPoints.map((item) => (
                    <li>{item}</li>
                  ))
                }
              </ul>
            </div>
          </div>
        </div>
      </section>

      <section class="section section--contact" id="contact">
        <div class="contact-shell glass-panel" data-reveal>
          <p class="section-kicker">{siteMetadata.contact.kicker}</p>
          <h2>{siteMetadata.contact.heading}</h2>
          <p>{siteMetadata.contact.note}</p>

          <div class="contact-actions">
            <a
              class="button button--primary"
              href={siteMetadata.primaryCTA.href}
              target="_blank"
              rel="noreferrer"
            >
              {siteMetadata.primaryCTA.label}
            </a>
            <a class="button button--secondary" href={siteMetadata.resumeUrl} target="_blank" rel="noreferrer">
              View Resume
            </a>
          </div>

          <div class="contact-meta">
            <a href={`mailto:${siteMetadata.email}`}>{siteMetadata.email}</a>
            <span>{siteMetadata.location}</span>
          </div>

          <ul class="hero-socials hero-socials--footer" aria-label="Social links">
            {
              siteMetadata.socialLinks.map((socialLink) => (
                <li>
                  <a href={socialLink.href} target="_blank" rel="noreferrer" aria-label={socialLink.label}>
                    <SocialIcon name={socialLink.id} />
                    <span>{socialLink.label}</span>
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </section>
    </main>

    <MotionController />
  </div>
</Layout>
